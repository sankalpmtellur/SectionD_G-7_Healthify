      <aliases enabled='yes' />
      <column caption='Readmission Rate' datatype='real' name='[Calculation_3975692833611776]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#10;IFNULL([readmitted_30_days], 0)&#10;)' />
      </column>
      <column caption='High Risk Patient %' datatype='real' name='[Calculation_3975692863578114]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#10;    IF [risk_tier] = &quot;high&quot; THEN [patient_id] END&#10;)&#10;/&#10;COUNT([patient_id])' />
      </column>
      <column caption='Overall Readmission Rate' datatype='real' name='[Calculation_3975692864544771]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([is_readmitted]) / COUNTD([patient_id])' />
      </column>
